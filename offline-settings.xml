<?xml version="1.0" encoding="UTF-8"?>
<!--
  Settings auxiliar para build OFFLINE com o cache local do ~/.m2.
  Nao define o mirror corporativo (nexus), permitindo que o Maven resolva
  os artefatos ja baixados sob o id de repositorio "central".
  Uso: mvn -o -s offline-settings.xml compile
-->
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 http://maven.apache.org/xsd/settings-1.0.0.xsd">
</settings>
